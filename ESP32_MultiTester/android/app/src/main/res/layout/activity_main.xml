<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ESP32 MultiTester"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/connectBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connect" />

        <Button
            android:id="@+id/pingBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ping" />
    </LinearLayout>

    <Button
        android:id="@+id/readNfcBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NFC: Read" />

    <Button
        android:id="@+id/writeNfcBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NFC: Write" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter text for NFC write"
            android:visibility="gone" />

        <Button
            android:id="@+id/sendDataBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send"
            android:visibility="gone" />
    </LinearLayout>

    <Button
        android:id="@+id/btDeauthBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BT Deauth"
        android:textColor="#CC0000" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log:"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/logView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a2e"
            android:textColor="#e0e0e0"
            android:padding="8dp"
            android:textSize="11sp"
            android:typeface="monospace" />
    </ScrollView>

</LinearLayout>
